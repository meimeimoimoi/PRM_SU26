# =============================================================================
# SmartDine — Backend env mẫu (Render / Docker)
# Copy thành .env (KHÔNG commit file .env thật).
# ASP.NET Core: Section__Key  (hai dấu gạch dưới)
# =============================================================================

ASPNETCORE_ENVIRONMENT=Production

# --- Postgres (Render Postgres → Internal/External Database URL) ---
ConnectionStrings__DefaultConnection=Host=dpg-d9cinpl7vvec73bf104g-a.singapore-postgres.render.com;Port=5432;Database=smartdine;Username=smartdine_user;Password=5E1z8iEqYr31uBbWJuX162khzD72H1SN;SSL Mode=Require;Trust Server Certificate=true

# --- JWT RSA (Identity ký bằng PrivateKey; các service khác chỉ cần PublicKey) ---
Jwt__Issuer=SmartDineAPI
Jwt__Audience=SmartDineApp
Jwt__
# Chỉ Identity.API:
Jwt__
# Jwt__AccessTokenExpiryMinutes=60
# Jwt__RefreshTokenExpiryDays=7

# --- PayOS (chỉ Order.API) ---
PayOS__ClientId=c16492d4-78a6-4dc6-87d5-a7b17daaa25d
PayOS__ApiKey=33ded071-8b3b-481f-a687-c8500b54c29d
PayOS__ChecksumKey=5eb26de1f12778b265b76d07f21d06160c41046dc698ca40c9160a0975624e1e

# URL redirect sau thanh toán online → trang Flutter Web trên Vercel
Payment__ReturnUrl=https://smartdine-app.vercel.app/payment/success
Payment__CancelUrl=https://smartdine-app.vercel.app/payment/cancel

# PayOS Dashboard → Webhook URL:
#   https://YOUR_GATEWAY.onrender.com/api/v1/payments/webhook

# --- Table.API: link QR bàn (mở Flutter Web) ---
CustomerWeb__BaseUrl=https://YOUR_FLUTTER_WEB.vercel.app

# --- Menu.API: URL công khai cho ảnh upload ---
Uploads__PublicBaseUrl=https://YOUR_GATEWAY.onrender.com

# --- Gateway: trỏ tới URL nội bộ từng microservice trên Render ---
# Ví dụ dùng internal hostname Render (thay bằng URL thật của bạn):
ReverseProxy__Clusters__auth-cluster__Destinations__destination1__Address=https://smartdine-indentity.onrender.com
ReverseProxy__Clusters__menu-cluster__Destinations__destination1__Address=http://smartdine-menu-api:10000
ReverseProxy__Clusters__orders-cluster__Destinations__destination1__Address=http://smartdine-order-api:10000
ReverseProxy__Clusters__tables-cluster__Destinations__destination1__Address=http://smartdine-table-api:10000
ReverseProxy__Clusters__ai-cluster__Destinations__destination1__Address=http://smartdine-ai-api:10000

