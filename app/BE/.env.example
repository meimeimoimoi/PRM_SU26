# =============================================================================
# SmartDine — Backend env mẫu (Render / Docker)
# Copy thành .env (KHÔNG commit file .env thật).
# ASP.NET Core: Section__Key  (hai dấu gạch dưới)
# =============================================================================

ASPNETCORE_ENVIRONMENT=Production

# --- Postgres (Render Postgres → Internal/External Database URL) ---
ConnectionStrings__DefaultConnection=Host=YOUR_DB_HOST;Port=5432;Database=smartdine;Username=YOUR_USER;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# --- JWT RSA (Identity ký bằng PrivateKey; các service khác chỉ cần PublicKey) ---
Jwt__Issuer=SmartDineAPI
Jwt__Audience=SmartDineApp
Jwt__RsaPublicKey=REPLACE_WITH_BASE64_RSA_PUBLIC_KEY
# Chỉ Identity.API:
Jwt__RsaPrivateKey=REPLACE_WITH_BASE64_RSA_PRIVATE_KEY
# Jwt__AccessTokenExpiryMinutes=60
# Jwt__RefreshTokenExpiryDays=7

# --- PayOS (chỉ Order.API) ---
PayOS__ClientId=REPLACE_WITH_PAYOS_CLIENT_ID
PayOS__ApiKey=REPLACE_WITH_PAYOS_API_KEY
PayOS__ChecksumKey=REPLACE_WITH_PAYOS_CHECKSUM_KEY

# URL redirect sau thanh toán online → trang Flutter Web trên Vercel
Payment__ReturnUrl=https://smartdine-phi.vercel.app/payment/success
Payment__CancelUrl=https://smartdine-phi.vercel.app/payment/cancel

# PayOS Dashboard → Webhook URL:
#   https://smartdine-gateway-veki.onrender.com/api/v1/payments/webhook

# --- Table.API: link QR bàn (mở Flutter Web) ---
CustomerWeb__BaseUrl=https://smartdine-phi.vercel.app

# --- Menu.API: URL công khai cho ảnh upload ---
Uploads__PublicBaseUrl=https://smartdine-gateway-veki.onrender.com

# --- Gateway: trỏ tới URL nội bộ từng microservice trên Render ---
# Ví dụ dùng internal hostname Render (thay bằng URL thật của bạn):
ReverseProxy__Clusters__auth-cluster__Destinations__destination1__Address=http://smartdine-identity-api:10000
ReverseProxy__Clusters__menu-cluster__Destinations__destination1__Address=http://smartdine-menu-api:10000
ReverseProxy__Clusters__orders-cluster__Destinations__destination1__Address=http://smartdine-order-api:10000
ReverseProxy__Clusters__tables-cluster__Destinations__destination1__Address=http://smartdine-table-api:10000
ReverseProxy__Clusters__ai-cluster__Destinations__destination1__Address=http://smartdine-ai-api:10000

# --- AI.API (tùy chọn) ---
# Services__Ollama=http://ollama:11434
# Services__OllamaModel=qwen2.5:1.5b
# Services__TableApi=http://smartdine-table-api:10000
# Services__MenuApi=http://smartdine-menu-api:10000
# Services__OrderApi=http://smartdine-order-api:10000

# --- Docker Compose local (tùy chọn) ---
POSTGRES_PASSWORD=password
