{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        }
      },
      "menu-route": {
        "ClusterId": "menu-cluster",
        "Match": {
          "Path": "/api/v1/menu-items/{**catch-all}"
        }
      },
      "orders-route": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Path": "/api/v1/orders/{**catch-all}"
        }
      },
      "tables-route": {
        "ClusterId": "tables-cluster",
        "Match": {
          "Path": "/api/v1/tables/{**catch-all}"
        }
      },
      "ai-route": {
        "ClusterId": "ai-cluster",
        "Match": {
          "Path": "/api/v1/ai/{**catch-all}"
        }
      },
      "staff-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/v1/staff/{**catch-all}"
        }
      },
      "settings-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/v1/settings/{**catch-all}"
        }
      },
      "menu-categories-route": {
        "ClusterId": "menu-cluster",
        "Match": {
          "Path": "/api/v1/menu-categories/{**catch-all}"
        }
      },
      "payments-route": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Path": "/api/v1/payments/{**catch-all}"
        }
      },
      "signalr-route": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Path": "/hubs/orders/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "menu-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "orders-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "tables-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5004"
          }
        }
      },
      "ai-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5005"
          }
        }
      }
    }
  }
}
