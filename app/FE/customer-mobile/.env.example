# =============================================================================
# SmartDine — Flutter customer-mobile
# Flutter dùng --dart-define (compile-time), không đọc .env runtime.
# File này chỉ là mẫu / ghi chú cho CI và Vercel build command.
# =============================================================================

# Có slash cuối /
API_BASE_URL=https://smartdine-gateway-veki.onrender.com/api/v1/

# Local:
#   flutter run
#   (mặc định http://localhost:5000/api/v1/)
#
# APK:
#   flutter build apk --release --dart-define=API_BASE_URL=https://YOUR_GATEWAY.onrender.com/api/v1/
#
# Flutter Web (Vercel):
#   flutter build web --release --dart-define=API_BASE_URL=https://YOUR_GATEWAY.onrender.com/api/v1/
